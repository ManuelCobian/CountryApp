<?xml version="1.0" encoding="utf-8"?>
<resources>

    <declare-styleable name="InputOutlineBox">
        <attr name="focusable" format="boolean" />
        <attr name="hintLayout" format="string" />
        <attr name="drawableRight" format="reference" />
        <attr name="maxLength" format="integer" />
        <attr name="type" format="enum">
            <enum name="edit_default" value="0" />
            <enum name="telephone" value="1" />
            <enum name="email" value="2" />
            <enum name="text" value="3" />
            <enum name="password" value="4" />
            <enum name="alphanumeric" value="5" />
            <enum name="date" value="6" />
        </attr>
    </declare-styleable>

</resources>