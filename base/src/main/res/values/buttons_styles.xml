<resources>

    <!-- Button-->
    <style name="Button">
        <item name="android:letterSpacing">0</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:minHeight">@dimen/spacing_empty</item>
        <item name="android:minWidth">@dimen/spacing_empty</item>
        <item name="android:textStyle">normal</item>
        <item name="fontFamily">@font/poppins</item>
        <item name="android:textColor">@color/white</item>
    </style>

    <style name="Button.Normal" parent="Button">
        <item name="android:paddingTop">@dimen/spacing_xstandard</item>
        <item name="android:paddingBottom">@dimen/spacing_xstandard</item>
        <item name="minHeight">@dimen/spacing_empty</item>
        <item name="android:paddingLeft">@dimen/spacing_standard</item>
        <item name="android:paddingRight">@dimen/spacing_standard</item>
        <item name="android:textSize">@dimen/font_subtitle</item>
        <item name="android:fontFamily">@font/poppins_semibold</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Button.Small" parent="Button">
        <item name="android:minWidth">@dimen/min_button_width</item>
        <item name="android:paddingTop">@dimen/spacing_empty</item>
        <item name="android:paddingBottom">@dimen/spacing_empty</item>
        <item name="android:paddingLeft">@dimen/spacing_medium</item>
        <item name="android:paddingRight">@dimen/spacing_medium</item>
        <item name="android:textSize">@dimen/font_caption1</item>
    </style>


    <style name="Button.Middle" parent="Button">
        <item name="android:minWidth">@dimen/min_button_middle_width</item>
        <item name="android:paddingTop">@dimen/spacing_standard</item>
        <item name="android:paddingBottom">@dimen/spacing_standard</item>
        <item name="android:paddingLeft">@dimen/spacing_medium</item>
        <item name="android:paddingRight">@dimen/spacing_medium</item>
        <item name="android:textSize">@dimen/font_caption1</item>
    </style>

    <style name="Button.White.Green.Border.Normal" parent="Button.Normal">
        <item name="android:backgroundTint">@color/purple_700</item>
        <item name="android:textColor">@color/gray_principal</item>
        <item name="fontFamily">@font/poppins_semibold</item>
        <item name="android:gravity">center</item>
    </style>

    <style name="TextView">
        <item name="android:letterSpacing">0</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:minHeight">@dimen/spacing_empty</item>
        <item name="android:minWidth">@dimen/spacing_empty</item>
        <item name="android:textStyle">normal</item>
        <item name="fontFamily">@font/poppins</item>
        <item name="android:textColor">@color/white</item>
    </style>

</resources>