<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/view_white_top_rounded_border"
    android:minHeight="@dimen/spacing_xvhiper"
    app:layout_constraintBottom_toBottomOf="parent">


    <ImageView
        android:id="@+id/imageView_close"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/spacing_xlarge"
        android:background="@drawable/bg_gray_circle"
        android:padding="@dimen/spacing_xxsmall"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/ic_closed" />

    <ImageView
        android:id="@+id/imageView_icon"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/spacing_xlarge"
        android:padding="@dimen/spacing_xxsmall"
        android:visibility="gone"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toBottomOf="@id/imageView_close" />

    <TextView
        android:id="@+id/textView_title"
        style="@style/TextH3.Black.Bold.Poppins"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_large"
        android:gravity="center"
        android:lineSpacingMultiplier="0.8"
        android:paddingLeft="@dimen/spacing_xlarge"
        android:paddingRight="@dimen/spacing_xlarge"
        app:layout_constrainedWidth="true"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toBottomOf="@id/imageView_icon"
        tools:text="Confirma si la fecha de vencimiento del producto es:" />

    <TextView
        android:id="@+id/textView_sub_title"
        style="@style/TextH2.Black"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_xstandard"
        android:layout_marginBottom="@dimen/spacing_xstandard"
        android:gravity="center"
        tools:text="Nueva Orden\nID 123123123"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toBottomOf="@id/textView_title"
        />


    <TextView
        android:id="@+id/button_confirm"
        style="@style/Button.Purple.Middle"
        android:layout_width="@dimen/spacing_empty"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/spacing_large"
        android:layout_marginTop="@dimen/spacing_xxlarge"
        android:layout_marginEnd="@dimen/spacing_standard"
        android:layout_marginBottom="@dimen/spacing_xxlarge"
        android:gravity="center"
        android:text="@string/tittle_cancel_btn"
        android:textColor="@color/white"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@id/textViewConfirmHelper"
        app:layout_constraintStart_toStartOf="@id/textView_sub_title"
        app:layout_constraintTop_toBottomOf="@id/textView_sub_title" />

    <TextView
        android:id="@+id/textViewConfirmHelper"
        style="@style/Button.Purple.Middle"
        android:layout_width="@dimen/spacing_empty"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_xxlarge"
        android:layout_marginEnd="@dimen/spacing_large"
        android:layout_marginBottom="@dimen/spacing_xxlarge"
        android:gravity="center"
        android:visibility="visible"
        android:text="@string/confirm_app"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="@id/textView_sub_title"
        app:layout_constraintStart_toEndOf="@+id/button_confirm"
        app:layout_constraintTop_toBottomOf="@id/textView_sub_title" />

</androidx.constraintlayout.widget.ConstraintLayout>