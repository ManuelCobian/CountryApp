<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@android:color/white">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="20dp"
        android:paddingTop="16dp"
        android:paddingEnd="20dp"
        android:paddingBottom="24dp">

        <ImageView
            android:id="@+id/imageViewClose"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:contentDescription="@string/closed_icon_description"
            android:src="@drawable/ic_closed"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/imgFlag"
            android:layout_width="150dp"
            android:layout_height="90dp"
            android:layout_marginTop="24dp"
            android:adjustViewBounds="true"
            android:contentDescription="Bandera del país"
            android:scaleType="fitCenter"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/imageViewClose"
            tools:src="@drawable/ic_launcher_foreground" />

        <TextView
            android:id="@+id/tvCommonName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="Mexico"
            android:textColor="#111111"
            android:textSize="30sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/imgFlag"
            tools:text="Ireland" />

        <TextView
            android:id="@+id/tvOfficialName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="United Mexican States"
            android:textColor="#8E8E93"
            android:textSize="18sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvCommonName"
            tools:text="Republic of Ireland" />

        <LinearLayout
            android:id="@+id/leftColumn"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:layout_marginEnd="12dp"
            android:orientation="vertical"
            app:layout_constraintEnd_toStartOf="@id/rightColumn"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvOfficialName"
            app:layout_constraintWidth_percent="0.48">

            <TextView
                android:id="@+id/labelCoatOfArms"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Coat of Arms"
                android:textColor="#111111"
                android:textSize="16sp"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/imgCoatOfArms"
                android:layout_width="70dp"
                android:layout_height="70dp"
                android:layout_marginTop="8dp"
                android:adjustViewBounds="true"
                android:contentDescription="Escudo del país"
                android:scaleType="fitCenter"
                tools:src="@drawable/ic_launcher_foreground" />

            <TextView
                android:id="@+id/labelRegion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Region"
                android:textColor="#111111"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvRegion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Americas"
                android:textColor="#8E8E93"
                android:textSize="16sp"
                tools:text="Europe" />

            <TextView
                android:id="@+id/labelSubregion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Subregion"
                android:textColor="#111111"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvSubregion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="North America"
                android:textColor="#8E8E93"
                android:textSize="16sp"
                tools:text="Northern Europe" />

            <TextView
                android:id="@+id/labelCapital"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Capital"
                android:textColor="#111111"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvCapital"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Mexico City"
                android:textColor="#8E8E93"
                android:textSize="16sp"
                tools:text="Dublin" />

            <TextView
                android:id="@+id/labelArea"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Area"
                android:textColor="#111111"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvArea"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="1,964,375"
                android:textColor="#8E8E93"
                android:textSize="16sp"
                tools:text="70,273" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/rightColumn"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:layout_marginStart="12dp"
            android:orientation="vertical"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/leftColumn"
            app:layout_constraintTop_toBottomOf="@id/tvOfficialName"
            app:layout_constraintWidth_percent="0.48">

            <TextView
                android:id="@+id/labelPopulation"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Population"
                android:textColor="#111111"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvPopulation"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="130,575,786"
                android:textColor="#8E8E93"
                android:textSize="16sp"
                tools:text="4,994,724" />

            <TextView
                android:id="@+id/labelLanguages"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Language(s)"
                android:textColor="#111111"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvLanguages"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Spanish"
                android:textColor="#8E8E93"
                android:textSize="16sp"
                tools:text="English&#10;Irish" />

            <TextView
                android:id="@+id/labelCarSide"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Car Driver Side"
                android:textColor="#111111"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvCarSide"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="RIGHT"
                android:textColor="#8E8E93"
                android:textSize="16sp"
                android:textStyle="bold"
                tools:text="RIGHT" />

            <TextView
                android:id="@+id/labelCurrencies"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Currencies"
                android:textColor="#111111"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvCurrencies"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="MXN ($ peso)"
                android:textColor="#8E8E93"
                android:textSize="16sp"
                tools:text="EUR (€ euro)" />

            <TextView
                android:id="@+id/labelTimezones"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Timezone(s)"
                android:textColor="#111111"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvTimezones"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="UTC-08:00, UTC-07:00, UTC-06:00"
                android:textColor="#8E8E93"
                android:textSize="16sp"
                tools:text="UTC" />
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>