<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="10dp"
    android:layout_marginEnd="10dp"
    android:layout_marginTop="5dp"
    android:layout_marginBottom="5dp"
    app:cardBackgroundColor="@color/whiteTextColor"
    app:cardCornerRadius="8dp"
    app:cardElevation="3dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp">

        <!-- Imagen del país -->
        <ImageView
            android:id="@+id/salesImageView"
            android:layout_width="80dp"
            android:layout_height="60dp"
            android:scaleType="centerCrop"
            android:contentDescription="@string/app_name"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <!-- Contenido -->
        <LinearLayout
            android:id="@+id/contentLayout"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:orientation="vertical"
            app:layout_constraintStart_toEndOf="@id/salesImageView"
            app:layout_constraintEnd_toStartOf="@id/img_favorite"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <TextView
                android:id="@+id/tv_name"
                style="@style/reportContentText"
                android:text="México"
                android:textColor="@color/purple"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_official"
                style="@style/viewParent.headerText"
                android:text="Estados Unidos Mexicanos"
                android:textSize="15sp"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tv_capital"
                style="@style/viewParent.contentText"
                android:text="Ciudad de México"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- Botón Favorito -->
        <ImageView
            android:id="@+id/img_favorite"
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:layout_marginEnd="8dp"
            android:src="@drawable/ic_favorite_border"
            android:contentDescription="Agregar a favoritos"
            android:clickable="true"
            android:focusable="true"
            app:tint="@color/black"
            app:layout_constraintEnd_toStartOf="@id/img_navigate"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <ImageView
            android:id="@+id/img_delete"
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:layout_marginEnd="8dp"
            android:src="@drawable/ic_trash"
            android:clickable="true"
            android:focusable="true"
            android:visibility="gone"
            app:tint="@color/black"
            app:layout_constraintEnd_toStartOf="@id/img_navigate"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <!-- Flecha navegar -->
        <ImageView
            android:id="@+id/img_navigate"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_navigate"
            app:tint="@color/gray_dark"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.cardview.widget.CardView>